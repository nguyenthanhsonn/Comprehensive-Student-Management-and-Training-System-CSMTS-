{
  "name": "smaste",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm -r build",
    "predev": "pnpm --filter @smaste/shared build",
    "dev": "pnpm --filter @smaste/backend start:dev",
    "dev:frontend": "pnpm --filter @smaste/frontend dev",
    "dev:backend": "pnpm --filter @smaste/backend start:dev",
    "db:generate": "pnpm --filter @smaste/backend db:generate",
    "db:migrate": "pnpm --filter @smaste/backend db:migrate",
    "db:deploy": "pnpm --filter @smaste/backend db:deploy",
    "db:studio": "pnpm --filter @smaste/backend db:studio",
    "db:seed": "pnpm --filter @smaste/backend db:seed",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "dotenv": "^17.4.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  }
}
