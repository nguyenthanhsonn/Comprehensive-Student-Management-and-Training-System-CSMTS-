# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smaste?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/smaste?schema=public"

# JWT
JWT_ACCESS_SECRET="replace-with-a-strong-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-different-strong-random-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
BACKEND_PORT=5050
BACKEND_HOST="127.0.0.1"
FRONTEND_URL="http://localhost:3000"
