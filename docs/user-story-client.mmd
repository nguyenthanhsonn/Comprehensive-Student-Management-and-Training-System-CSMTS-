flowchart TD
    START([Người dùng truy cập hệ thống])

    %% =========================
    %% A. ĐĂNG NHẬP VÀ PHÂN QUYỀN
    %% =========================
    subgraph A[A. Luồng đăng nhập và phân quyền]
        A_NOTE[/Chú thích: Xác thực người dùng trước khi cho truy cập hệ thống/]
        A1[Người dùng mở hệ thống]
        A2[Nhập tài khoản / mật khẩu]
        A3[Client kiểm tra dữ liệu đầu vào cơ bản]
        A4[Gửi request đăng nhập lên Server]
        A5[Server xác thực tài khoản]
        A6{Thông tin đăng nhập đúng?}
        A7[Server trả token / session]
        A8[Client lưu thông tin đăng nhập]
        A9[Điều hướng đến trang chính]
        A10[Hiển thị thông báo lỗi]
    end

    %% =========================
    %% B. QUẢN LÝ HỒ SƠ SINH VIÊN
    %% =========================
    subgraph B[B. Luồng quản lý hồ sơ sinh viên]
        B_NOTE[/Chú thích: Quản lý thông tin cá nhân, hồ sơ và dữ liệu sinh viên/]
        B1[Người dùng vào module Sinh viên]
        B2[Xem danh sách sinh viên]
        B3[Tìm kiếm / lọc / phân trang]
        B4[Chọn sinh viên cần xem]
        B5[Xem chi tiết hồ sơ]
        B6[Thêm / sửa / xóa / cập nhật thông tin]
        B7[Gửi dữ liệu lên Server]
        B8[Server kiểm tra và cập nhật CSDL]
        B9[Client hiển thị kết quả]
    end

    %% =========================
    %% C. QUẢN LÝ KẾT QUẢ HỌC TẬP
    %% =========================
    subgraph C[C. Luồng quản lý kết quả học tập]
        C_NOTE[/Chú thích: Theo dõi, nhập điểm, tính điểm trung bình và thống kê học tập/]
        C1[Người dùng vào module Học tập]
        C2[Xem điểm theo học kỳ / năm học]
        C3[Chọn lớp / sinh viên / môn học]
        C4[Nhập hoặc chỉnh sửa điểm]
        C5[Hệ thống tính điểm trung bình và xếp loại]
        C6[Gửi dữ liệu cập nhật lên Server]
        C7[Server lưu lại kết quả]
        C8[Client hiển thị bảng điểm / tổng hợp / thống kê]
    end

    %% =========================
    %% D. QUẢN LÝ RÈN LUYỆN
    %% =========================
    subgraph D[D. Luồng quản lý rèn luyện]
        D_NOTE[/Chú thích: Đánh giá điểm rèn luyện theo học kỳ hoặc đợt đánh giá/]
        D1[Người dùng vào module Rèn luyện]
        D2[Chọn học kỳ / đợt đánh giá]
        D3[Hiển thị phiếu đánh giá]
        D4[Nhập các tiêu chí điểm rèn luyện]
        D5[Hệ thống tự tính điểm tổng]
        D6[Phân loại kết quả rèn luyện]
        D7[Gửi dữ liệu lên Server]
        D8[Lưu kết quả]
        D9[Client hiển thị xác nhận]
    end

    %% =========================
    %% E. KHEN THƯỞNG - KỶ LUẬT
    %% =========================
    subgraph E[E. Luồng quản lý khen thưởng - kỷ luật]
        E_NOTE[/Chú thích: Lưu trữ quyết định khen thưởng, kỷ luật và minh chứng đi kèm/]
        E1[Người dùng vào module Khen thưởng / Kỷ luật]
        E2[Xem danh sách bản ghi]
        E3[Thêm mới hồ sơ khen thưởng / kỷ luật]
        E4[Đính kèm minh chứng nếu có]
        E5[Gửi dữ liệu lên Server]
        E6[Server kiểm tra hợp lệ và lưu CSDL]
        E7[Client cập nhật trạng thái hiển thị]
    end

    %% =========================
    %% F. HOẠT ĐỘNG SINH VIÊN
    %% =========================
    subgraph F[F. Luồng quản lý hoạt động sinh viên]
        F_NOTE[/Chú thích: Quản lý hoạt động ngoại khóa, nghiên cứu khoa học và phong trào/]
        F1[Người dùng vào module Hoạt động]
        F2[Xem danh sách hoạt động ngoại khóa / NCKH / phong trào]
        F3[Tham gia hoặc cập nhật minh chứng]
        F4[Hệ thống ghi nhận điểm hoặc trạng thái tham gia]
        F5[Gửi dữ liệu lên Server]
        F6[Server xử lý và lưu CSDL]
        F7[Client hiển thị kết quả tổng hợp]
    end

    %% =========================
    %% G. TRA CỨU - BÁO CÁO
    %% =========================
    subgraph G[G. Luồng tra cứu - báo cáo]
        G_NOTE[/Chú thích: Tìm kiếm dữ liệu, xem báo cáo và xuất file phục vụ quản lý/]
        G1[Người dùng chọn chức năng tra cứu]
        G2[Nhập điều kiện tìm kiếm]
        G3[Client gửi query lên Server]
        G4[Server trả danh sách kết quả]
        G5[Client hiển thị bảng / biểu đồ / file xuất]
        G6[Xuất PDF / Excel / in ấn]
    end

    %% =========================
    %% MAIN FLOW
    %% =========================
    START --> A_NOTE
    A_NOTE --> A1
    A1 --> A2
    A2 --> A3
    A3 --> A4
    A4 --> A5
    A5 --> A6

    A6 -- Đúng --> A7
    A7 --> A8
    A8 --> A9

    A6 -- Sai --> A10
    A10 --> A2

    %% Sau khi đăng nhập thành công, người dùng có thể vào các module
    A9 --> B_NOTE
    A9 --> C_NOTE
    A9 --> D_NOTE
    A9 --> E_NOTE
    A9 --> F_NOTE
    A9 --> G_NOTE

    %% B flow
    B_NOTE --> B1
    B1 --> B2
    B2 --> B3
    B3 --> B4
    B4 --> B5
    B5 --> B6
    B6 --> B7
    B7 --> B8
    B8 --> B9

    %% C flow
    C_NOTE --> C1
    C1 --> C2
    C2 --> C3
    C3 --> C4
    C4 --> C5
    C5 --> C6
    C6 --> C7
    C7 --> C8

    %% D flow
    D_NOTE --> D1
    D1 --> D2
    D2 --> D3
    D3 --> D4
    D4 --> D5
    D5 --> D6
    D6 --> D7
    D7 --> D8
    D8 --> D9

    %% E flow
    E_NOTE --> E1
    E1 --> E2
    E2 --> E3
    E3 --> E4
    E4 --> E5
    E5 --> E6
    E6 --> E7

    %% F flow
    F_NOTE --> F1
    F1 --> F2
    F2 --> F3
    F3 --> F4
    F4 --> F5
    F5 --> F6
    F6 --> F7

    %% G flow
    G_NOTE --> G1
    G1 --> G2
    G2 --> G3
    G3 --> G4
    G4 --> G5
    G5 --> G6

    %% =========================
    %% STYLE COLORS
    %% =========================

    %% Start
    classDef startStyle fill:#212529,stroke:#000,color:#fff,stroke-width:2px;

    %% Login
    classDef loginStyle fill:#E3F2FD,stroke:#1565C0,color:#0D47A1,stroke-width:2px;
    classDef loginNote fill:#BBDEFB,stroke:#0D47A1,color:#0D47A1,stroke-width:2px,stroke-dasharray: 5 5;

    %% Student Profile
    classDef studentStyle fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20,stroke-width:2px;
    classDef studentNote fill:#C8E6C9,stroke:#1B5E20,color:#1B5E20,stroke-width:2px,stroke-dasharray: 5 5;

    %% Study Result
    classDef studyStyle fill:#FFF3E0,stroke:#EF6C00,color:#E65100,stroke-width:2px;
    classDef studyNote fill:#FFE0B2,stroke:#E65100,color:#E65100,stroke-width:2px,stroke-dasharray: 5 5;

    %% Training
    classDef conductStyle fill:#F3E5F5,stroke:#7B1FA2,color:#4A148C,stroke-width:2px;
    classDef conductNote fill:#E1BEE7,stroke:#4A148C,color:#4A148C,stroke-width:2px,stroke-dasharray: 5 5;

    %% Reward Discipline
    classDef rewardStyle fill:#FFEBEE,stroke:#C62828,color:#B71C1C,stroke-width:2px;
    classDef rewardNote fill:#FFCDD2,stroke:#B71C1C,color:#B71C1C,stroke-width:2px,stroke-dasharray: 5 5;

    %% Activities
    classDef activityStyle fill:#E0F7FA,stroke:#00838F,color:#006064,stroke-width:2px;
    classDef activityNote fill:#B2EBF2,stroke:#006064,color:#006064,stroke-width:2px,stroke-dasharray: 5 5;

    %% Report
    classDef reportStyle fill:#F1F8E9,stroke:#558B2F,color:#33691E,stroke-width:2px;
    classDef reportNote fill:#DCEDC8,stroke:#33691E,color:#33691E,stroke-width:2px,stroke-dasharray: 5 5;

    %% Decision
    classDef decisionStyle fill:#FFF9C4,stroke:#F9A825,color:#795548,stroke-width:2px;

    %% Apply style
    class START startStyle;

    class A1,A2,A3,A4,A5,A7,A8,A9,A10 loginStyle;
    class A_NOTE loginNote;
    class A6 decisionStyle;

    class B1,B2,B3,B4,B5,B6,B7,B8,B9 studentStyle;
    class B_NOTE studentNote;

    class C1,C2,C3,C4,C5,C6,C7,C8 studyStyle;
    class C_NOTE studyNote;

    class D1,D2,D3,D4,D5,D6,D7,D8,D9 conductStyle;
    class D_NOTE conductNote;

    class E1,E2,E3,E4,E5,E6,E7 rewardStyle;
    class E_NOTE rewardNote;

    class F1,F2,F3,F4,F5,F6,F7 activityStyle;
    class F_NOTE activityNote;

    class G1,G2,G3,G4,G5,G6 reportStyle;
    class G_NOTE reportNote;