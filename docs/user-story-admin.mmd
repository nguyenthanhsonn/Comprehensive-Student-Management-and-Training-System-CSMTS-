flowchart TD
    A([Admin đăng nhập hệ thống])
    B[Hệ thống xác thực tài khoản admin]
    C[Admin truy cập trang quản trị]
    D[Chọn chức năng cần quản lý]
    E[Nhập hoặc chỉnh sửa dữ liệu]
    F[Gửi dữ liệu lên Server]
    G[Server kiểm tra dữ liệu hợp lệ]
    H[(Server lưu hoặc cập nhật vào CSDL)]
    I[Client hiển thị thông báo thành công / thất bại]

    A --> B
    B --> C
    C --> D
    D --> E
    E --> F
    F --> G
    G --> H
    H --> I

    classDef admin fill:#E3F2FD,stroke:#1565C0,color:#0D47A1,stroke-width:2px;
    classDef client fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20,stroke-width:2px;
    classDef server fill:#FFF3E0,stroke:#EF6C00,color:#E65100,stroke-width:2px;
    classDef database fill:#F3E5F5,stroke:#7B1FA2,color:#4A148C,stroke-width:2px;

    class A,C,D,E admin;
    class I client;
    class B,F,G server;
    class H database;